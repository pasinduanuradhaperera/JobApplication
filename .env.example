# Core AI generation key (required for modules 1, 2, and 4; optional fallback for 5)
DEEPSEEK_API_KEY=

# Outbound email settings (required to actually send emails in modules 1 and 4)
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# SMTP override (optional; defaults used in code if blank)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Job search provider key (optional; app falls back to scraping when blank)
SERPAPI_KEY=
